# ── AWS credentials ──────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── S3 ───────────────────────────────────────────────────────────────────────
S3_BUCKET_NAME=prod-support-kb-docs

# ── Bedrock resource IDs (populated automatically by Phase 1 scripts) ────────
BEDROCK_AGENT_ID=
BEDROCK_AGENT_ALIAS_ID=
BEDROCK_ROLE_ARN=
LAMBDA_ROLE_ARN=

# ── Monitoring (optional) ─────────────────────────────────────────────────────
# SNS topic ARN for CloudWatch alarms (set up in step 9)
SNS_ALERTS_ARN=
